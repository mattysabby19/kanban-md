@page "/"
@using Kanban.Md.App.Models
@using Kanban.Md.App.Services
@using Microsoft.JSInterop
@inject TaskRepository Repo
@inject TaskRepositoryOptions Options
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Board — kanban-md</PageTitle>

<header class="board-header">
    <h1>kanban-md</h1>
    <span class="board-source" title="Tasks directory">@Options.Directory</span>
</header>

@if (_error is not null)
{
    <div class="board-error">
        <strong>Failed to load or save tasks.</strong>
        <pre>@_error</pre>
    </div>
}
@if (_tasks is null)
{
    <p>Loading…</p>
}
else if (_tasks.Count == 0)
{
    <p class="board-empty">No tasks found in <code>@Options.Directory</code>.</p>
}
else
{
    <section class="board">
        @foreach (var status in _columns)
        {
            var tasksInColumn = _tasks.Where(t => t.Status == status).ToList();
            <div class="board-column">
                <header class="column-header">
                    <span class="column-title">@status</span>
                    <span class="column-count">@tasksInColumn.Count</span>
                </header>
                <div class="column-body" id="col-@status" data-column-status="@status">
                    @foreach (var task in tasksInColumn)
                    {
                        <article class="card priority-@task.Priority.ToString().ToLowerInvariant()"
                                 data-task-id="@task.Id"
                                 @key="task.Id">
                            <div class="card-meta">
                                <span class="card-id">@task.Id</span>
                                <span class="badge badge-priority">@task.Priority</span>
                                <span class="badge badge-effort">@task.Effort</span>
                            </div>
                            <div class="card-title">@task.Title</div>
                            @if (task.Labels.Count > 0)
                            {
                                <div class="card-labels">
                                    @foreach (var label in task.Labels)
                                    {
                                        <span class="label">@label</span>
                                    }
                                </div>
                            }
                            <div class="card-footer">
                                <span class="card-epic">@task.Epic</span>
                                @if (task.Assignee is not null)
                                {
                                    <span class="card-assignee">@task.Assignee</span>
                                }
                            </div>
                        </article>
                    }
                </div>
            </div>
        }
    </section>
}

@code {
    private static readonly KanbanStatus[] _columns =
    {
        KanbanStatus.Backlog,
        KanbanStatus.Todo,
        KanbanStatus.InProgress,
        KanbanStatus.Review,
        KanbanStatus.Done,
        KanbanStatus.Blocked,
    };

    private IReadOnlyList<KanbanTask>? _tasks;
    private string? _error;
    private DotNetObjectReference<Home>? _objRef;
    private bool _dndInitialized;

    protected override void OnInitialized()
    {
        try
        {
            _tasks = Repo.LoadAll();
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_dndInitialized && _tasks is not null && _tasks.Count > 0)
        {
            _objRef = DotNetObjectReference.Create(this);
            var columnIds = _columns.Select(s => $"col-{s}").ToArray();
            await JS.InvokeVoidAsync("kanbanInit", _objRef, columnIds);
            _dndInitialized = true;
        }
    }

    [JSInvokable]
    public async Task OnTaskMovedAsync(string taskId, string newStatusName)
    {
        if (_tasks is null)
        {
            return;
        }

        var task = _tasks.FirstOrDefault(t => t.Id == taskId);
        if (task is null)
        {
            return;
        }

        if (!Enum.TryParse<KanbanStatus>(newStatusName, ignoreCase: false, out var newStatus))
        {
            return;
        }

        if (task.Status == newStatus)
        {
            return;
        }

        try
        {
            var updated = task with
            {
                Status = newStatus,
                Updated = DateOnly.FromDateTime(DateTime.UtcNow.Date),
            };
            Repo.Save(updated);
            _tasks = Repo.LoadAll();
            _error = null;
        }
        catch (Exception ex)
        {
            _error = ex.ToString();
        }

        await InvokeAsync(StateHasChanged);
    }

    public ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
        return ValueTask.CompletedTask;
    }
}
